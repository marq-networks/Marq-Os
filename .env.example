## Frontend → API base URL
# When you want the frontend to use the real API services:
# - set USE_MOCK_SERVICES = false in `src/app/services/config.ts`
# - set this value to your API base (must include `/v1`)
VITE_API_BASE_URL=http://127.0.0.1:5174/v1

## API server (`npm run dev:api`)
PORT=5174
HOST=127.0.0.1

## API JWT secret (dev only)
# Used by the Express API in `apps/api` to sign/verify Bearer tokens
API_JWT_SECRET=dev-secret-change-me

## API + Postgres via Supabase (set when `USE_SUPABASE_DB=true`)
USE_SUPABASE_DB=false
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_DEFAULT_ORG_ID=11111111-1111-1111-1111-111111111111

## Supabase (optional, if you connect UI directly to Supabase)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

## Database (server-side only — never expose to frontend)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

